# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# design system docs (local-only reference for AI agents, not pushed)
/docs/*
/docs/**/*
# Ngoại lệ: setup guide public (cho developer mới + reviewer PR)
!/docs/SETUP_SUPABASE.md
!/docs/SETUP_OAUTH.md

# Supabase CLI workspaces
/supabase/.branches/
/supabase/.temp/
/supabase/logs/

# Claude Code
/.claude/worktrees/
/.claude/plans/

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/

# Turbo
/.turbo/

# Cache
/.cache/
/.swc/

# IDE
/.vscode/
/.idea/
*.swp
*.swo

# OS
Thumbs.db

# Large files for submission
/docs/report/*.webm
/docs/report/*.mp4
