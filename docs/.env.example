# ────────────────────────────────────────────────────────────────────
# Lumio — biến môi trường mẫu
#
# Copy file này thành `.env.local` rồi điền giá trị thật.
# KHÔNG commit `.env.local` (đã có trong .gitignore).
#
# Lấy giá trị:
# - Supabase: dashboard https://app.supabase.com/project/<ref>/settings/api
# - Gemini:   https://aistudio.google.com/apikey
# - Upstash:  https://console.upstash.com/redis/<id>/details/rest
# ────────────────────────────────────────────────────────────────────

# ─── Supabase ───────────────────────────────────────────────────────
# Project URL — dán đúng URL có format https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co

# Anon key — public, bound RLS. An toàn để expose ra browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service role key — BYPASS RLS. CHỈ dùng trong:
#   1. app/api/cron/* (xác thực bằng CRON_SECRET trước)
#   2. Migration / admin script chạy thủ công
# KHÔNG bao giờ load vào client component / browser bundle.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─── Google Gemini ──────────────────────────────────────────────────
# API key cho @google/genai SDK
GEMINI_API_KEY=AIza...

# ─── OpenRouter (LLM fallback) ──────────────────────────────────────
# Lấy tại https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# ─── Whisper fallback (Replicate hoặc Together) ─────────────────────
REPLICATE_API_TOKEN=r8_...
# Hoặc: TOGETHER_API_KEY=...

# ─── Upstash Redis (rate limiting) ──────────────────────────────────
# REST URL + token. Sẽ dùng bởi @upstash/ratelimit trong middleware
# và mỗi Server Action AI.
UPSTASH_REDIS_REST_URL=https://....upstash.io
UPSTASH_REDIS_REST_TOKEN=AY...

# ─── Cron secret ────────────────────────────────────────────────────
# Random string 32+ ký tự. Generate bằng: `openssl rand -hex 32`
# Mọi route /api/cron/* check `Authorization: Bearer ${CRON_SECRET}`
CRON_SECRET=please-replace-with-openssl-rand-hex-32

# ─── Sentry (tuỳ chọn — error tracking) ─────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ─── PostHog (tuỳ chọn — product analytics) ─────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── App config ─────────────────────────────────────────────────────
# Public site URL — dùng cho OAuth callback, email link, sitemap.
# Local: http://localhost:3000
# Preview: https://<branch>-<project>.vercel.app
# Production: https://lumio.app (hoặc domain thật)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── LanguageTool (tuỳ chọn — grammar pre-check) ────────────────────
# Để trống = dùng public API (rate limit 20 req/phút)
# Hoặc self-host và đặt URL đầy đủ
LANGUAGETOOL_API_URL=

# ─── Feature flags (tuỳ chọn) ───────────────────────────────────────
# Bật/tắt phần đang dev cho từng env
NEXT_PUBLIC_FEATURE_PLACEMENT_TEST=true
NEXT_PUBLIC_FEATURE_AI_QUIZ=true
NEXT_PUBLIC_FEATURE_SPEAKING=false
