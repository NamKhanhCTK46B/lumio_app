# Site URL — dùng cho email redirect (production) và absolute URLs
# Production: https://lumio.nguyenhoangnamkhanh.id.vn
# Local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
# Anon key — JWT (định dạng cũ) HOẶC sb_publishable_* (định dạng mới). Cả hai đều dùng cùng biến này.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — JWT (định dạng cũ) HOẶC sb_secret_* (định dạng mới). Chỉ dùng trong app/api/cron/*.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase CLI (push migration từ máy dev hoặc CI)
# Lấy access token tại https://app.supabase.com/account/tokens
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# OAuth — Google (https://console.cloud.google.com/apis/credentials)
# Hướng dẫn chi tiết: docs/SETUP_OAUTH.md §2
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=

# OAuth — Facebook (https://developers.facebook.com/apps)
# Hướng dẫn chi tiết: docs/SETUP_OAUTH.md §3
SUPABASE_AUTH_FACEBOOK_CLIENT_ID=
SUPABASE_AUTH_FACEBOOK_SECRET=

# Google Gemini — https://aistudio.google.com
GEMINI_API_KEY=

# OpenRouter (dự phòng) — https://openrouter.ai
OPENROUTER_API_KEY=

# Upstash Redis (rate limit) — https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron secret — random 32-char string
CRON_SECRET=

# Sentry (tuỳ chọn)
SENTRY_DSN=

# Google Cloud Speech (Speech-to-Text & Text-to-Speech)
# Hướng dẫn chi tiết: docs/VOICE.md
# Lấy credentials tại Google Cloud Console → IAM → Service Accounts → Keys
GOOGLE_CLOUD_PROJECT_ID=
# JSON của service account, escape newlines bằng \n trong một dòng
GOOGLE_CLOUD_CREDENTIALS_JSON='{"type": "service_account", ...}'
GOOGLE_CLOUD_STT_ENABLED="false"
GOOGLE_CLOUD_TTS_ENABLED="false"
SPEECH_PROVIDER_DEFAULT="web"
SPEECH_FALLBACK_ENABLED="true"
