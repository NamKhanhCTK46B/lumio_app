# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# (Optional) Supabase publishable key — định dạng mới (sb_publishable_*), thay anon JWT.
SUPABASE_PUBLISHABLE_KEY=

# Google Gemini — https://aistudio.google.com
GEMINI_API_KEY=

# OpenRouter (dự phòng) — https://openrouter.ai
OPENROUTER_API_KEY=

# Upstash Redis (rate limit) — https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron secret — random 32-char string
CRON_SECRET=

# Sentry (tuỳ chọn)
SENTRY_DSN=
